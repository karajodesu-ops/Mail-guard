{
    "name": "mailguard/sdk-php",
    "description": "Official PHP SDK for MailGuard OTP and Email API",
    "type": "library",
    "keywords": ["otp", "email", "verification", "mailguard", "authentication", "php"],
    "license": "MIT",
    "authors": [
        {
            "name": "MailGuard OSS",
            "email": "support@mailguard.dev"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "ext-curl": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^3.7",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "MailGuard\\Sdk\&quot;: "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MailGuard\\Sdk\\Tests\&quot;: "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse src --level=max",
        "check": "phpcs --standard=PSR12 src/"
    },
    "support": {
        "issues": "https://github.com/mailguard/mailguard/issues",
        "source": "https://github.com/mailguard/mailguard"
    },
    "homepage": "https://github.com/mailguard/mailguard"
}